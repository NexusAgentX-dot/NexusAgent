PORT=8787
NEXUSAGENT_ALPHA_SIGNAL_RPC_URL=https://rpc.xlayer.tech
NEXUSAGENT_ALPHA_SIGNAL_CHAIN_ID=196
NEXUSAGENT_ALPHA_MAX_GAS_PRICE_WEI=30000000
NEXUSAGENT_ALPHA_EXECUTION_MODE=disabled
NEXUSAGENT_ALLOWED_ORIGINS=
# NEXUSAGENT_ALLOW_PUBLIC_WORKSPACE_LIST=1

# Signal provider: okx_market (default) | xlayer_rpc (legacy gas price signal)
NEXUSAGENT_ALPHA_SIGNAL_PROVIDER=okx_market

# Workspace quota (default 50 runs/day)
# NEXUSAGENT_MAX_RUNS_PER_DAY=50

# OKX Onchain OS API credentials (required for okx_market signal + Onchain OS features)
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=
# OKX_PROJECT_ID=

